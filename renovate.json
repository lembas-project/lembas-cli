{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "commitMessageLowerCase": "never",
  "extends": [
    "config:recommended"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all rattler crates together",
      "groupName": "rattler",
      "matchManagers": [
        "cargo"
      ],
      "matchPackageNames": [
        "/^rattler/"
      ]
    }
  ]
}
